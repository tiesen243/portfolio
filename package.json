{
  "name": "portfolio",
  "private": true,
  "homepage": "https://tiesen.id.vn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiesen243/portfolio.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "build": "bun run --filter @yuki/web build",
    "clean": "bun run --filter '*' clean && git clean -xdf node_modules",
    "dev": "bun run --filter @yuki/web dev",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "turbo": "^2.9.14"
  },
  "packageManager": "bun@1.3.0",
  "catalogs": {
    "prod": {
      "@tanstack/react-query": "^5.90.12",
      "zod": "^4.4.3"
    },
    "dev": {
      "@types/node": "^25.9.1",
      "tsdown": "^0.21.7",
      "typescript": "^6.0.3"
    },
    "react": {
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3",
      "react": "^19.2.6",
      "react-dom": "^19.2.6"
    },
    "tailwind": {
      "@tailwindcss/postcss": "^4.3.0",
      "@tailwindcss/vite": "^4.2.2",
      "tailwindcss": "^4.3.0"
    }
  }
}
